  "keyFeatures": [
    "Real-time 4-player multiplayer Spades via WebSocket",
    "Table lobby with public, friends-only, and private visibility",
    "Flexible join policies: open, friends-only, invite-only",
    "Shareable single-use join links and multi-use spectator links",
    "In-app friend system with presence (online / in-game / offline)",
    "Bot players to fill empty seats for solo testing and mid-game replacements",
    "Blind Nil bidding with card exchange protocol",
    "Server-side anti-cheat move validation",
    "Redis-backed session management, presence state, and pub/sub fan-out",
    "PostgreSQL persistence with career stats and recent game history",
    "Rate limiting on authentication and social endpoints",
    "Player profiles with avatars, cosmetics, and career records"
  ],
